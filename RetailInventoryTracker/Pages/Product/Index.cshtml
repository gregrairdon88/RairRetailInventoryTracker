@page "/product/{id?}"
@model RetailInventoryTracker.Pages.Product.IndexModel
@{
    ViewData["Title"] = Model.IsNew ? "Add Product" : "Edit Product";
}

<div class="page-header">
    <div>
        <h1>@(Model.IsNew ? "Add New Product" : "Edit Product")</h1>
        <p class="page-sub">@(Model.IsNew ? "Add a product to your inventory" : Model.Product.Name)</p>
    </div>
</div>

<div class="form-card">
    <form method="post">
        @if (!Model.IsNew)
        {
            <input type="hidden" asp-for="Product.Id" />
        }

        <div class="form-section">
            <h3><i class="fas fa-box"></i> Product Details</h3>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Product.Name">Product Name *</label>
                    <input asp-for="Product.Name" placeholder="e.g. Claw Hammer 16oz" class="form-input" />
                    <span asp-validation-for="Product.Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Product.Sku">SKU *</label>
                    <input asp-for="Product.Sku" placeholder="e.g. HW-1001" class="form-input" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Product.Barcode">Barcode</label>
                    <div class="input-with-btn">
                        <input asp-for="Product.Barcode" id="barcode-field" placeholder="e.g. 012345678905" class="form-input" />
                        <button type="button" class="btn-icon btn-scan"
                                onclick="BarcodeScanner.open(function(v){ document.getElementById('Product_Barcode').value = v; })"
                                title="Scan barcode">
                            <i class="fas fa-barcode"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Product.Category">Category *</label>
                    <input asp-for="Product.Category" placeholder="e.g. Hardware & Tools" list="category-list" class="form-input" />
                    <datalist id="category-list">
                        @foreach (var cat in Model.ExistingCategories)
                        {
                            <option value="@cat" />
                        }
                    </datalist>
                </div>
                <div class="form-group">
                    <label asp-for="Product.Supplier">Supplier</label>
                    <input asp-for="Product.Supplier" placeholder="e.g. Midwest Supply Co" class="form-input" />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3><i class="fas fa-dollar-sign"></i> Pricing</h3>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Product.CostPrice">Cost Price *</label>
                    <input asp-for="Product.CostPrice" type="number" step="0.01" class="form-input" />
                </div>
                <div class="form-group">
                    <label asp-for="Product.SellPrice">Sell Price *</label>
                    <input asp-for="Product.SellPrice" type="number" step="0.01" class="form-input" />
                </div>
                <div class="form-group">
                    <label>Margin</label>
                    <div class="form-static">
                        @if (Model.Product.SellPrice > 0 && Model.Product.CostPrice > 0)
                        {
                            <span class="@(Model.Product.Margin >= 30 ? "text-green" : Model.Product.Margin >= 15 ? "text-warning" : "text-danger")">
                                @Model.Product.Margin%
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">&mdash;</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3><i class="fas fa-cubes"></i> Stock</h3>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Product.QuantityOnHand">Quantity on Hand</label>
                    <input asp-for="Product.QuantityOnHand" type="number" class="form-input" />
                </div>
                <div class="form-group">
                    <label asp-for="Product.ReorderLevel">Reorder Level</label>
                    <input asp-for="Product.ReorderLevel" type="number" class="form-input" />
                    <span class="form-hint">You'll see a warning when stock falls to this level</span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3><i class="fas fa-sticky-note"></i> Notes</h3>
            <div class="form-group">
                <textarea asp-for="Product.Notes" rows="3" placeholder="Optional notes about this product…" class="form-input"></textarea>
            </div>
        </div>

        <div class="form-actions">
            <a href="/inventory" class="btn-outline">Cancel</a>

            @if (!Model.IsNew)
            {
                <button type="submit" asp-page-handler="Delete" class="btn-danger"
                        onclick="return confirm('Delete this product?')">
                    <i class="fas fa-trash"></i> Delete
                </button>
            }

            <button type="submit" class="btn-primary">
                <i class="fas fa-save"></i> @(Model.IsNew ? "Add Product" : "Save Changes")
            </button>
        </div>
    </form>
</div>
