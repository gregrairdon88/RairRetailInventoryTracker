@page "/low-stock"
@inject InventoryService Svc

<PageTitle>Low Stock Alerts — StockSimple</PageTitle>

<div class="page-header">
    <div>
        <h1><i class="fas fa-exclamation-triangle text-warning"></i> Low Stock Alerts</h1>
        <p class="page-sub">@items.Count item@(items.Count == 1 ? "" : "s") need attention</p>
    </div>
    <a href="/inventory" class="btn-outline"><i class="fas fa-arrow-left"></i> Back to Inventory</a>
</div>

@if (items.Count == 0)
{
    <div class="card">
        <div class="card-body">
            <div class="empty-state">
                <i class="fas fa-check-circle" style="color: var(--green);"></i>
                <h3>Everything's in good shape!</h3>
                <p>No products are below their reorder level.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="low-stock-grid">
        @foreach (var p in items)
        {
            <div class="low-stock-card @(p.IsOutOfStock ? "out-of-stock" : "")">
                <div class="low-stock-header">
                    <span class="stock-badge @(p.IsOutOfStock ? "badge-danger" : "badge-warning")">
                        @(p.IsOutOfStock ? "OUT OF STOCK" : $"{p.QuantityOnHand} left")
                    </span>
                    <span class="text-muted">@p.Sku</span>
                </div>
                <h3>@p.Name</h3>
                <p class="text-muted">@p.Category &middot; @p.Supplier</p>
                <div class="low-stock-meta">
                    <span>Reorder at: <strong>@p.ReorderLevel</strong></span>
                    <span>On hand: <strong class="@(p.IsOutOfStock ? "text-danger" : "text-warning")">@p.QuantityOnHand</strong></span>
                </div>
                <div class="low-stock-actions">
                    <button class="btn-primary btn-sm" @onclick="() => QuickAdd(p.Id)">
                        <i class="fas fa-plus"></i> Add 10
                    </button>
                    <a href="/product/@p.Id" class="btn-outline btn-sm">
                        <i class="fas fa-pen"></i> Edit
                    </a>
                </div>
            </div>
        }
    </div>
}

@code {
    List<Product> items = [];

    protected override void OnInitialized()
    {
        LoadItems();
    }

    void LoadItems()
    {
        items = Svc.GetLowStock();
    }

    void QuickAdd(Guid id)
    {
        Svc.AdjustStock(id, 10);
        LoadItems();
    }
}
