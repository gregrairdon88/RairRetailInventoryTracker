@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";

    string NavClass(string page, string? also = null) =>
        currentPage == page || (also != null && currentPage == also) ? "nav-item active" : "nav-item";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="StockSimple — Inventory tracking for small retail businesses." />
    <title>@ViewData["Title"] — StockSimple</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body>
    <div class="app-layout">

        <!-- ═══════════ SIDEBAR ═══════════ -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <a href="/" class="sidebar-brand" id="sidebar-brand-full">
                    <i class="fas fa-boxes-stacked"></i>
                    <span>StockSimple</span>
                </a>
                <a href="/" class="sidebar-brand collapsed-brand" id="sidebar-brand-collapsed" style="display:none">
                    <i class="fas fa-boxes-stacked"></i>
                </a>
            </div>

            <div class="sidebar-nav">
                <a href="/" class="@NavClass("/Index")">
                    <i class="fas fa-chart-line"></i>
                    <span class="sidebar-label">Dashboard</span>
                </a>
                <a href="/inventory" class="@NavClass("/Inventory")">
                    <i class="fas fa-box"></i>
                    <span class="sidebar-label">Inventory</span>
                </a>
                <a href="/product/new" class="@NavClass("/Product/Create")">
                    <i class="fas fa-plus-circle"></i>
                    <span class="sidebar-label">Add Product</span>
                </a>
                <a href="/low-stock" class="@NavClass("/LowStock")">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span class="sidebar-label">Low Stock</span>
                </a>
            </div>

            <button class="sidebar-toggle desktop-toggle" id="sidebar-toggle" title="Toggle sidebar">
                <i class="fas fa-angles-left" id="sidebar-toggle-icon"></i>
            </button>
        </nav>

        <!-- ═══════════ MOBILE TOP BAR ═══════════ -->
        <div class="mobile-topbar">
            <button class="mobile-menu-btn" id="mobile-menu-btn">
                <i class="fas fa-bars" id="mobile-menu-icon"></i>
            </button>
            <a href="/" class="mobile-brand">
                <i class="fas fa-boxes-stacked"></i> StockSimple
            </a>
        </div>
        <div class="mobile-overlay" id="mobile-overlay" style="display:none"></div>

        <!-- ═══════════ MAIN AREA ═══════════ -->
        <div class="main-area">
            <main class="main-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="site-footer">
        <p>&copy; @DateTime.Now.Year StockSimple &mdash; Inventory Tracker Demo</p>
        <p class="footer-credit">
            <i class="fas fa-code"></i>
            Built by <a href="https://rairsolutions.com" target="_blank" rel="noopener">Rair Solutions</a>
        </p>
    </footer>

    <script>
        (function () {
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const toggleIcon = document.getElementById('sidebar-toggle-icon');
            const brandFull = document.getElementById('sidebar-brand-full');
            const brandCollapsed = document.getElementById('sidebar-brand-collapsed');
            const labels = document.querySelectorAll('.sidebar-label');

            function setCollapsed(collapsed) {
                if (collapsed) {
                    sidebar.classList.add('collapsed');
                    toggleIcon.className = 'fas fa-angles-right';
                    brandFull.style.display = 'none';
                    brandCollapsed.style.display = '';
                    labels.forEach(el => el.style.display = 'none');
                } else {
                    sidebar.classList.remove('collapsed');
                    toggleIcon.className = 'fas fa-angles-left';
                    brandFull.style.display = '';
                    brandCollapsed.style.display = 'none';
                    labels.forEach(el => el.style.display = '');
                }
                localStorage.setItem('sidebar-collapsed', String(collapsed));
            }

            const savedCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
            setCollapsed(savedCollapsed);

            toggleBtn.addEventListener('click', function () {
                setCollapsed(!sidebar.classList.contains('collapsed'));
            });

            // Mobile menu
            const mobileBtn = document.getElementById('mobile-menu-btn');
            const mobileIcon = document.getElementById('mobile-menu-icon');
            const overlay = document.getElementById('mobile-overlay');

            function setMobileOpen(open) {
                sidebar.classList.toggle('mobile-open', open);
                overlay.style.display = open ? '' : 'none';
                mobileIcon.className = open ? 'fas fa-times' : 'fas fa-bars';
            }

            mobileBtn.addEventListener('click', function () {
                setMobileOpen(!sidebar.classList.contains('mobile-open'));
            });
            overlay.addEventListener('click', function () {
                setMobileOpen(false);
            });
        })();
    </script>

    <!-- ═══════ BARCODE SCANNER MODAL ═══════ -->
    <div id="bs-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:2000;align-items:center;justify-content:center;">
        <div class="bs-container">
            <div class="bs-header">
                <h3><i class="fas fa-barcode"></i> Scan Barcode</h3>
                <button class="bs-close" onclick="BarcodeScanner.close()" title="Close">&times;</button>
            </div>
            <div class="bs-viewport">
                <video id="bs-video" autoplay playsinline muted></video>
                <div class="bs-line"></div>
            </div>
            <p id="bs-status" class="bs-status">Initializing&hellip;</p>
        </div>
    </div>

    <script src="https://unpkg.com/@@zxing/library@@0.21.3/umd/index.min.js"></script>
    <script src="~/js/barcode-scanner.js" asp-append-version="true"></script>
</body>
</html>
